{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Netflix Content Strategy — Exploratory Data Analysis\n",
    "\n",
    "**Dataset:** Netflix Movies & TV Shows (Kaggle, 8,807 titles)\n",
    "\n",
    "This notebook performs full exploratory analysis: content distribution, ratings, countries, genres, duration, and lifecycle."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from collections import Counter\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "\n",
    "df = pd.read_csv('../data/netflix_titles.csv')\n",
    "df['date_added'] = pd.to_datetime(df['date_added'], errors='coerce')\n",
    "df['year_added'] = df['date_added'].dt.year"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Dataset Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Records: 8,807\n",
      "Movies: 6,131 (69.6%)\n",
      "TV Shows: 2,676 (30.4%)\n",
      "Date range added: 2008-01-01 to 2021-09-25\n",
      "Release years: 1925 to 2021\n"
     ]
    }
   ],
   "source": [
    "print(f\"Records: {len(df):,}\")\n",
    "print(f\"Movies: {len(df[df['type']=='Movie']):,} ({len(df[df['type']=='Movie'])/len(df)*100:.1f}%)\")\n",
    "print(f\"TV Shows: {len(df[df['type']=='TV Show']):,} ({len(df[df['type']=='TV Show'])/len(df)*100:.1f}%)\")\n",
    "print(f\"Date range added: {df['date_added'].min()} to {df['date_added'].max()}\")\n",
    "print(f\"Release years: {df['release_year'].min()} to {df['release_year'].max()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Missing Values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "director: 2,634 (29.9%)\n",
      "cast: 825 (9.4%)\n",
      "country: 554 (6.3%)\n",
      "date_added: 10 (0.1%)\n",
      "rating: 7 (0.1%)\n",
      "duration: 7 (0.1%)\n"
     ]
    }
   ],
   "source": [
    "missing = df.isnull().sum()\n",
    "missing_pct = (missing / len(df) * 100).round(1)\n",
    "for col in missing[missing > 0].index:\n",
    "    print(f\"  {col}: {missing[col]:,} ({missing_pct[col]}%)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Content Type Distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Movie      6131\n",
      "TV Show    2676\n",
      "Name: type, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "type_counts = df['type'].value_counts()\n",
    "print(type_counts)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "colors = ['#E50914', '#221F1F']\n",
    "axes[0].pie(type_counts, labels=type_counts.index, autopct='%1.1f%%', colors=colors, startangle=90)\n",
    "axes[0].set_title('Netflix Content Mix')\n",
    "sns.countplot(data=df, x='type', palette=colors, ax=axes[1])\n",
    "axes[1].set_title('Movies vs TV Shows')\n",
    "axes[1].set_ylabel('Count')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Rating Distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "TV-MA       3207\n",
      "TV-14       2160\n",
      "TV-PG        863\n",
      "R            799\n",
      "PG-13        490\n",
      "TV-Y7        334\n",
      "TV-Y         307\n",
      "PG           287\n",
      "TV-G         220\n",
      "NR            80\n",
      "Name: rating, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "rating_counts = df['rating'].value_counts().head(10)\n",
    "print(rating_counts)\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "sns.countplot(data=df, x='rating', order=rating_counts.index, palette='Reds_r')\n",
    "plt.title('Content Rating Distribution')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Top Content-Producing Countries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "United States         3690\n",
      "India               1046\n",
      "United Kingdom       806\n",
      "Canada               445\n",
      "France               393\n",
      "Japan                318\n",
      "Spain                232\n",
      "South Korea          231\n",
      "Germany              226\n",
      "Mexico               169\n",
      "dtype: int64\n"
     ]
    }
   ],
   "source": [
    "countries = []\n",
    "for entry in df['country'].dropna():\n",
    "    countries.extend([c.strip() for c in entry.split(',')])\n",
    "country_counts = pd.Series(Counter(countries)).sort_values(ascending=False)\n",
    "print(country_counts.head(10))\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "top15 = country_counts.head(15)\n",
    "sns.barplot(x=top15.values, y=top15.index, palette='Reds_r')\n",
    "plt.title('Top 15 Content-Producing Countries on Netflix')\n",
    "plt.xlabel('Number of Titles')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Genre Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "International Movies         2752\n",
      "Dramas                       2427\n",
      "Comedies                     1674\n",
      "International TV Shows       1351\n",
      "Documentaries                 869\n",
      "Action & Adventure            859\n",
      "TV Dramas                     763\n",
      "Independent Movies            756\n",
      "Children & Family Movies      641\n",
      "Romantic Movies               616\n",
      "dtype: int64\n"
     ]
    }
   ],
   "source": [
    "genres = []\n",
    "for entry in df['listed_in'].dropna():\n",
    "    genres.extend([g.strip() for g in entry.split(',')])\n",
    "genre_counts = pd.Series(Counter(genres)).sort_values(ascending=False)\n",
    "print(genre_counts.head(10))\n",
    "\n",
    "plt.figure(figsize=(12, 10))\n",
    "top20 = genre_counts.head(20)\n",
    "sns.barplot(x=top20.values, y=top20.index, palette='Reds_r')\n",
    "plt.title('Top 20 Genres on Netflix')\n",
    "plt.xlabel('Number of Titles')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Release Year Trends"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [],
   "source": [
    "release_by_year = df.groupby(['release_year', 'type']).size().unstack(fill_value=0)\n",
    "plt.figure(figsize=(14, 6))\n",
    "release_by_year['Movie'].plot(label='Movies', color='#E50914', linewidth=2)\n",
    "release_by_year['TV Show'].plot(label='TV Shows', color='#221F1F', linewidth=2)\n",
    "plt.title('Content Release Year Trends')\n",
    "plt.xlabel('Release Year')\n",
    "plt.ylabel('Number of Titles')\n",
    "plt.legend()\n",
    "plt.xlim(1990, 2022)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Content Addition Trends by Year"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "type        Movie  TV Show\n",
      "year_added              \n",
      "2012.0          3        0\n",
      "2013.0          6        4\n",
      "2014.0         19        4\n",
      "2015.0         56       17\n",
      "2016.0        253      165\n",
      "2017.0        839      325\n",
      "2018.0       1237      388\n",
      "2019.0       1424      575\n",
      "2020.0       1284      594\n",
      "2021.0        993      505\n"
     ]
    }
   ],
   "source": [
    "addition_by_year = df.groupby(['year_added', 'type']).size().unstack(fill_value=0)\n",
    "print(addition_by_year.tail(10))\n",
    "\n",
    "plt.figure(figsize=(14, 6))\n",
    "addition_by_year['Movie'].plot(label='Movies', color='#E50914', linewidth=2)\n",
    "addition_by_year['TV Show'].plot(label='TV Shows', color='#221F1F', linewidth=2)\n",
    "plt.title('Netflix Content Addition by Year')\n",
    "plt.xlabel('Year Added to Netflix')\n",
    "plt.ylabel('Number of Titles Added')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Duration Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Average movie runtime: 99.6 minutes\n",
      "Median movie runtime: 98.0 minutes\n",
      "TV Show season distribution:\n",
      "seasons\n",
      "1.0     1793\n",
      "2.0      425\n",
      "3.0      199\n",
      "4.0       95\n",
      "5.0       65\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "df_movies = df[df['type'] == 'Movie'].copy()\n",
    "df_movies['duration_min'] = df_movies['duration'].str.extract(r'(\d+)').astype(float)\n",
    "print(f\"Average movie runtime: {df_movies['duration_min'].mean():.1f} minutes\")\n",
    "print(f\"Median movie runtime: {df_movies['duration_min'].median():.1f} minutes\")\n",
    "\n",
    "df_tv = df[df['type'] == 'TV Show'].copy()\n",
    "df_tv['seasons'] = df_tv['duration'].str.extract(r'(\d+)').astype(float)\n",
    "print(f\"TV Show season distribution:\")\n",
    "print(df_tv['seasons'].value_counts().sort_index().head(10))\n",
    "\n",
    "plt.figure(figsize=(14, 5))\n",
    "plt.subplot(1, 2, 1)\n",
    "sns.histplot(df_movies['duration_min'].dropna(), bins=50, color='#E50914')\n",
    "plt.title('Movie Runtime Distribution')\n",
    "plt.subplot(1, 2, 2)\n",
    "sns.countplot(data=df_tv, x='seasons', color='#221F1F')\n",
    "plt.title('TV Show Season Distribution')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Content Lifecycle (Release → Netflix)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Average years to Netflix: 4.4\n",
      "Median years to Netflix: 1.0\n"
     ]
    }
   ],
   "source": [
    "df['years_to_netflix'] = df['year_added'] - df['release_year']\n",
    "lifecycle = df[(df['years_to_netflix'] >= 0) & (df['years_to_netflix'] <= 50)]\n",
    "print(f\"Average years to Netflix: {lifecycle['years_to_netflix'].mean():.1f}\")\n",
    "print(f\"Median years to Netflix: {lifecycle['years_to_netflix'].median():.1f}\")\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "sns.histplot(data=lifecycle, x='years_to_netflix', hue='type', bins=50, palette=['#E50914', '#221F1F'])\n",
    "plt.title('Years from Release to Addition on Netflix')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
